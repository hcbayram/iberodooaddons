<?xml version="1.0" encoding="UTF-8"?>
<odoo>
  <data>
    <record model="ir.ui.view" id="inh_res_config_settings_view_form">
      <field name="name">res.config.settings.form.inheirt</field>
      <field name="model">res.config.settings</field>
      <field name="inherit_id" ref="sale.res_config_settings_view_form"/>
      <field name="arch" type="xml">
        <xpath expr="//block[@name='quotation_order_setting_container']/setting[@id='order_warnings']" position="after">
          <div class="col-12 col-lg-6 o_setting_box" id="config_allow_sale_warehouse">
            <div class="o_setting_left_pane">
              <field name="allow_sale_warehouse"/>
            </div>
            <div class="o_setting_right_pane">
              <label for="allow_sale_warehouse"/>
              <span class="fa fa-lg fa-building-o" title="Values set here are allow warehouse in sale order line."/>
              <div class="text-muted">
                      Allow different warehouse for every sale order lines.
              </div>
            </div>
          </div>
        </xpath>
      </field>
    </record>
  </data>
</odoo>
