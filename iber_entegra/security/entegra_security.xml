<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="group_entegra_user" model="res.groups">
            <field name="name">Entegra / Kullanıcı</field>
        </record>

        <record id="group_entegra_manager" model="res.groups">
            <field name="name">Entegra / Yönetici</field>
            <field name="implied_ids" eval="[(4, ref('group_entegra_user'))]"/>
        </record>

        <!-- Çok şirketli erişim kuralları -->
        <record id="rule_entegra_config_company" model="ir.rule">
            <field name="name">Entegra Config: Şirket Bazlı</field>
            <field name="model_id" ref="model_iber_entegra_config"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
            <field name="groups" eval="[(4, ref('group_entegra_user'))]"/>
        </record>

        <record id="rule_entegra_order_company" model="ir.rule">
            <field name="name">Entegra Sipariş: Şirket Bazlı</field>
            <field name="model_id" ref="model_iber_entegra_order"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
            <field name="groups" eval="[(4, ref('group_entegra_user'))]"/>
        </record>

        <record id="rule_entegra_product_mapping_company" model="ir.rule">
            <field name="name">Entegra Ürün Eşleşmesi: Şirket Bazlı</field>
            <field name="model_id" ref="model_iber_entegra_product_mapping"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
            <field name="groups" eval="[(4, ref('group_entegra_user'))]"/>
        </record>

    </data>
</odoo>
