<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Form -->
    <record id="view_iber_entegra_order_form" model="ir.ui.view">
        <field name="name">iber.entegra.order.form</field>
        <field name="model">iber.entegra.order</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_create_sale_order" type="object"
                            string="Satış Siparişi Oluştur" class="btn-primary"
                            invisible="sale_order_id != False"/>
                    <button name="action_update_status" type="object"
                            string="Durumu Güncelle"/>
                    <button name="action_send_shipment" type="object"
                            string="Kargoya Ver"
                            invisible="not cargo_company"/>
                    <button name="action_mark_erp_synced" type="object"
                            string="ERP'de İşaretlendi"
                            invisible="api_sync != 0"/>
                    <field name="status" widget="statusbar"
                           statusbar_visible="1,2,3,4,5,6,8"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="order_number" readonly="1"/>
                        </h1>
                        <h3>
                            <field name="supplier" readonly="1"/>
                            <span> — </span>
                            <field name="order_id" readonly="1"/>
                        </h3>
                    </div>

                    <group>
                        <group string="Sipariş Bilgileri">
                            <field name="config_id" readonly="1"/>
                            <field name="order_date" readonly="1"/>
                            <field name="payment_type" readonly="1"/>
                            <field name="discount" readonly="1"/>
                            <field name="total_amount" readonly="1"/>
                            <field name="sale_order_id"/>
                        </group>
                        <group string="ERP / Sync">
                            <field name="erp_order_number"/>
                            <field name="sync" readonly="1"/>
                            <field name="api_sync" readonly="1"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Kalemler">
                            <field name="line_ids" readonly="1">
                                <list>
                                    <field name="product_code"/>
                                    <field name="product_name"/>
                                    <field name="quantity"/>
                                    <field name="price"/>
                                    <field name="first_price"/>
                                    <field name="subtotal"/>
                                    <field name="product_mapping_id"/>
                                </list>
                            </field>
                        </page>
                        <page string="Müşteri">
                            <group>
                                <group string="Kişi Bilgileri">
                                    <field name="full_name" readonly="1"/>
                                    <field name="email" readonly="1"/>
                                    <field name="mobile_phone" readonly="1"/>
                                    <field name="phone" readonly="1"/>
                                    <field name="tc_id" readonly="1"/>
                                    <field name="tax_number" readonly="1"/>
                                    <field name="tax_office" readonly="1"/>
                                </group>
                            </group>
                        </page>
                        <page string="Adresler">
                            <group>
                                <group string="Fatura Adresi">
                                    <field name="invoice_fullname" readonly="1"/>
                                    <field name="invoice_address" readonly="1"/>
                                    <field name="invoice_district" readonly="1"/>
                                    <field name="invoice_city" readonly="1"/>
                                    <field name="invoice_postcode" readonly="1"/>
                                </group>
                                <group string="Teslimat Adresi">
                                    <field name="ship_fullname" readonly="1"/>
                                    <field name="ship_address" readonly="1"/>
                                    <field name="ship_district" readonly="1"/>
                                    <field name="ship_city" readonly="1"/>
                                    <field name="ship_postcode" readonly="1"/>
                                </group>
                            </group>
                        </page>
                        <page string="Kargo">
                            <group>
                                <group string="Gelen Kargo Bilgisi">
                                    <field name="cargo" readonly="1"/>
                                    <field name="cargo_code" readonly="1"/>
                                    <field name="cargo_payment_method" readonly="1"/>
                                </group>
                                <group string="Güncellenecek Kargo Bilgisi">
                                    <field name="cargo_company"/>
                                    <field name="cargo_code2"/>
                                    <field name="cargo_follow_url"/>
                                    <field name="cargo_send_date"/>
                                </group>
                            </group>
                        </page>
                        <page string="Fatura">
                            <group>
                                <field name="invoice_url"/>
                                <field name="invoice_number"/>
                                <field name="invoice_date"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- List -->
    <record id="view_iber_entegra_order_list" model="ir.ui.view">
        <field name="name">iber.entegra.order.list</field>
        <field name="model">iber.entegra.order</field>
        <field name="arch" type="xml">
            <list decoration-warning="status in ('1','2','3')"
                  decoration-success="status == '5'"
                  decoration-muted="status in ('6','7','12','13')">
                <field name="order_number"/>
                <field name="supplier"/>
                <field name="order_id"/>
                <field name="full_name"/>
                <field name="order_date"/>
                <field name="total_amount" sum="Toplam"/>
                <field name="status" widget="badge"
                       decoration-warning="status in ('1','2','3')"
                       decoration-info="status == '4'"
                       decoration-success="status == '5'"
                       decoration-danger="status in ('6','11','12','13')"
                       decoration-muted="status in ('8','14','15')"/>
                <field name="api_sync" optional="hide"/>
                <field name="cargo_company" optional="hide"/>
            </list>
        </field>
    </record>

    <!-- Search -->
    <record id="view_iber_entegra_order_search" model="ir.ui.view">
        <field name="name">iber.entegra.order.search</field>
        <field name="model">iber.entegra.order</field>
        <field name="arch" type="xml">
            <search>
                <field name="order_number"/>
                <field name="full_name"/>
                <filter name="filter_unsynced" string="Senkronize Edilmemiş"
                        domain="[('api_sync', '=', 0)]"/>
                <filter name="filter_pending" string="Bekleyen"
                        domain="[('status', 'in', ('1', '2', '3'))]"/>
                <filter name="filter_shipped" string="Kargoda"
                        domain="[('status', '=', '4')]"/>
                <filter name="filter_delivered" string="Teslim Edildi"
                        domain="[('status', '=', '5')]"/>
                <filter name="filter_cancelled" string="İptal"
                        domain="[('status', 'in', ('6', '12', '13'))]"/>
                <group>
                    <filter name="group_supplier" string="Pazaryeri"
                            context="{'group_by': 'supplier'}"/>
                    <filter name="group_status" string="Durum"
                            context="{'group_by': 'status'}"/>
                    <filter name="group_date" string="Sipariş Tarihi"
                            context="{'group_by': 'order_date:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_iber_entegra_order" model="ir.actions.act_window">
        <field name="name">Siparişler</field>
        <field name="res_model">iber.entegra.order</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_iber_entegra_order_search"/>
    </record>

</odoo>
