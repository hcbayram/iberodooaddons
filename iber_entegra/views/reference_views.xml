<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Kategoriler -->
    <record id="view_iber_entegra_category_list" model="ir.ui.view">
        <field name="name">iber.entegra.category.list</field>
        <field name="model">iber.entegra.category</field>
        <field name="arch" type="xml">
            <list>
                <field name="entegra_id"/>
                <field name="name"/>
                <field name="parent_id"/>
            </list>
        </field>
    </record>

    <record id="view_iber_entegra_category_form" model="ir.ui.view">
        <field name="name">iber.entegra.category.form</field>
        <field name="model">iber.entegra.category</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="entegra_id"/>
                        <field name="parent_id"/>
                        <field name="company_id"/>
                    </group>
                    <field name="child_ids" readonly="1">
                        <list>
                            <field name="entegra_id"/>
                            <field name="name"/>
                        </list>
                    </field>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_iber_entegra_category" model="ir.actions.act_window">
        <field name="name">Kategoriler</field>
        <field name="res_model">iber.entegra.category</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Markalar -->
    <record id="view_iber_entegra_brand_list" model="ir.ui.view">
        <field name="name">iber.entegra.brand.list</field>
        <field name="model">iber.entegra.brand</field>
        <field name="arch" type="xml">
            <list>
                <field name="entegra_id"/>
                <field name="name"/>
                <field name="company_id"/>
            </list>
        </field>
    </record>

    <record id="action_iber_entegra_brand" model="ir.actions.act_window">
        <field name="name">Markalar</field>
        <field name="res_model">iber.entegra.brand</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Mağazalar -->
    <record id="view_iber_entegra_store_list" model="ir.ui.view">
        <field name="name">iber.entegra.store.list</field>
        <field name="model">iber.entegra.store</field>
        <field name="arch" type="xml">
            <list>
                <field name="entegra_id"/>
                <field name="name"/>
                <field name="marketplace"/>
                <field name="config_id"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="action_iber_entegra_store" model="ir.actions.act_window">
        <field name="name">Mağazalar</field>
        <field name="res_model">iber.entegra.store</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
